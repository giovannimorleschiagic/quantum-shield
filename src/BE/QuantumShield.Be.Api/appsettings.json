{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SqlDatabase": {
    "ConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=QuantumShield.Be;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "evaluation-templates",
    "DefaultTemplateBlobName": "default-template.json"
  },
  "KeyVault": {
    "VaultUri": "https://your-key-vault-name.vault.azure.net/"
  },
  "Graph": {
    "Scopes": [
      "https://graph.microsoft.com/.default"
    ]
  }
}
